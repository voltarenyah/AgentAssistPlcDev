<Window x:Class="App.ConfirmToolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sandbox approval"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Topmost="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="The agent wants to run a destructive tool:" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="1" x:Name="ToolNameText" FontFamily="Consolas" FontSize="14" Margin="0,8,0,0"/>
        <TextBlock Grid.Row="2" x:Name="ArgumentsText" TextWrapping="Wrap" Foreground="Gray" Margin="0,4,0,0"/>
        <TextBlock Grid.Row="3" x:Name="BudgetText" FontSize="11" Foreground="Gray" Margin="0,10,0,0"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Allow once" Click="OnAllowOnce" Padding="12,4" Margin="0,0,8,0"/>
            <Button Content="Allow for session" Click="OnAllowSession" Padding="12,4" Margin="0,0,8,0"/>
            <Button Content="Deny" IsCancel="True" Padding="12,4"/>
        </StackPanel>
    </Grid>
</Window>
